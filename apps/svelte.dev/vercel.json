{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"rewrites": [
		{
			"source": "/opencode/schema.json",
			"destination": "https://raw.githubusercontent.com/sveltejs/ai-tools/refs/heads/main/packages/opencode/schema.json"
		}
	],
	"headers": [
		{
			"source": "/_app/immutable/workers/(.*)",
			"headers": [
				{
					"key": "cross-origin-opener-policy",
					"value": "same-origin"
				},
				{
					"key": "cross-origin-embedder-policy",
					"value": "require-corp"
				},
				{
					"key": "cross-origin-resource-policy",
					"value": "cross-origin"
				}
			]
		},
		{
			"source": "/tutorial/kit/(.*)",
			"headers": [
				{
					"key": "cross-origin-opener-policy",
					"value": "same-origin"
				},
				{
					"key": "cross-origin-embedder-policy",
					"value": "require-corp"
				},
				{
					"key": "cross-origin-resource-policy",
					"value": "cross-origin"
				}
			]
		}
	]
}
